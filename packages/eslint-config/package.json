{
  "name": "@alphayou/cs",
  "type": "module",
  "version": "0.3.0",
  "description": "Alpha You's ESLint config preset",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint-config"
  ],
  "author": "Amano Fuon <amanofuon@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphayou/codestyle",
    "directory": "packages/eslint-config"
  },
  "bugs": "https://github.com/alphayou/codestyle/issues",
  "readme": "https://github.com/alphayou/codestyle#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typegen": "esno scripts/typegen/generate.ts",
    "build": "pnpm typegen && tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "beta",
    "@typescript-eslint/eslint-plugin": "8.0.0-alpha.37",
    "@typescript-eslint/parser": "8.0.0-alpha.37",
    "eslint-plugin-jsonc": "^2.16.0",
    "globals": "^15.8.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^0.5.0"
  }
}
