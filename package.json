  "license": "MIT",
  "devDependencies": {
    "@alphayou/cs": "workspace:*",
    "@eslint/config-inspector": "^0.5.1",
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.14.9",
    "bumpp": "^9.4.1",
    "eslint": "^9.5.0",
    "eslint-typegen": "^0.2.4",
    "esno": "^4.7.0",
    "pnpm": "^9.4.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2"
  }
}
