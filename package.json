{
  "name": "@alphayou/codestyle-monorepo",
  "private": true,
  "type": "module",
  "version": "0.2.2",
  "description": "Alpha You's codestyle monorepo",
  "scripts": {
    "build": "pnpm run -r --filter=./packages/* build",
    "dev": "eslint-config-inspector",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "dep": "taze -r",
    "dep:w": "taze -rw",
    "typecheck": "pnpm run -r --filter=./packages/* typecheck",
    "release": "bumpp --no-push --recursive",
    "prepare": "simple-git-hooks"
  },
  "author": "Amano Fuon <amanofuon@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@alphayou/cs": "workspace:*",
    "@eslint/config-inspector": "^0.5.1",
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.14.10",
    "bumpp": "^9.4.1",
    "changelogithub": "^0.13.7",
    "eslint": "^9.6.0",
    "eslint-typegen": "^0.2.4",
    "esno": "^4.7.0",
    "lint-staged": "^15.2.7",
    "pnpm": "^9.4.0",
    "simple-git-hooks": "^2.11.1",
    "taze": "^0.13.9",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": [
      "pnpm lint:fix"
    ]
  }
}
