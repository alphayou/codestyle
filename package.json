{
  "name": "@alphayou/codestyle-monorepo",
  "private": true,
  "type": "module",
  "version": "0.1.12",
  "description": "Alpha You's codestyle monorepo",
  "scripts": {
    "build": "pnpm run -r --filter=./packages/* build",
    "dev": "eslint-config-inspector",
    "typecheck": "pnpm run -r --filter=./packages/* typecheck",
